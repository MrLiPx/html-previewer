{
  "redirects": [
    { "source": "/index.html", "destination": "/",    "permanent": true, "statusCode": 308 },
    { "source": "/app.html",   "destination": "/app", "permanent": true, "statusCode": 308 },
    { "source": "/404.html",   "destination": "/404", "permanent": true, "statusCode": 308 }
  ],
  "cleanUrls": true,
  "images": {
    "sizes": [16, 32, 48, 64, 96, 128, 256, 384, 512],
    "domains": [
      "avatars.githubusercontent.com",
      "mrlipx.github.io"
    ],
    "formats": ["image/avif", "image/webp"],
    "minimumCacheTTL": 3600,
    "dangerouslyAllowSVG": true,
    "contentSecurityPolicy": "default-src 'none'; img-src 'self' data:"
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options",        "value": "SAMEORIGIN" },
        { "key": "X-XSS-Protection",       "value": "1; mode=block" },
        { "key": "Referrer-Policy",        "value": "strict-origin-when-cross-origin" }
      ]
    },
    {
      "source": "/media/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(app|index|404)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    }
  ]
}
