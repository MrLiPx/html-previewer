# _redirects — goes in the REPO ROOT (same folder as index.html and app.html)
# Netlify and Cloudflare Pages pick this up automatically.
#
# 308 = Permanent Redirect (preserves POST method, SEO-safe)
# Query strings (?foo=bar) are forwarded automatically.
# Hash fragments (#...) are client-side only — browsers re-attach them after redirect.

/index.html   /    308
/app.html     /app 308
/404.html     /404 308
